# ──────────────────────────────────────────────────────────────────────────────
#  ISTC AI Bot – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git!
# ──────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
WEBHOOK_SECRET=change_me_to_a_random_string

# ── AI Provider: "gemini" or "openai" ─────────────────────────────────────────
AI_PROVIDER=gemini

# ── Google Gemini (if AI_PROVIDER=gemini) ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI (if AI_PROVIDER=openai) ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Bot Config ─────────────────────────────────────────────────────────────────
BOT_NAME=ISTC AI Assistant
MAX_HISTORY=20
SYSTEM_PROMPT=You are ISTC AI, a helpful and friendly assistant. Answer clearly and concisely. Always respond in the same language the user writes in.

# ── Railway Webhook (set automatically by Railway) ────────────────────────────
# WEBHOOK_URL=https://your-app.up.railway.app
# PORT=8443
